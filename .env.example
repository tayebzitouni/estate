DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
AUTH_SECRET="replace-with-a-long-random-production-secret"
APP_URL="https://your-domain.com"

# Optional production email provider. If missing, verification links are written to .temp/email-outbox.log.
RESEND_API_KEY=""
EMAIL_FROM="Darak <noreply@your-domain.com>"

S3_BUCKET="darak-assets"
S3_REGION="eu-west-1"
S3_ENDPOINT="https://example-s3.local"
